<?xml version="1.0" encoding="UTF-8"?>

<ResourceDictionary
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml">

    <!-- Note: For Android please see also Platforms\Android\Resources\values\colors.xml -->

    <Color x:Key="White">#FFFFFF</Color>
    <Color x:Key="Black">#000000</Color>
    <Color x:Key="Gray50">#FAFAFA</Color>
    <Color x:Key="Gray100">#E1E1E1</Color>
    <Color x:Key="Gray800">#2A2A2A</Color>
    <Color x:Key="Gray900">#1A1A1A</Color>
    <Color x:Key="Blue600">#2543EB</Color>
    <Color x:Key="Red600">#DC2626</Color>

    <SolidColorBrush x:Key="AppBackgroundColor"
                     Color="{AppThemeBinding Light={StaticResource White},
                                                           Dark={StaticResource Gray900}}" />
    <SolidColorBrush x:Key="AppTextColor"
                     Color="{AppThemeBinding Light={StaticResource Gray900}, 
                                                           Dark={StaticResource Gray50}}" />
    <SolidColorBrush x:Key="Primary"
                     Color="{AppThemeBinding Light={StaticResource  Blue600}, 
                                                           Dark={StaticResource Blue600}}" />
    <SolidColorBrush x:Key="Danger"
                     Color="{AppThemeBinding Light={StaticResource Red600},
                                                           Dark={StaticResource Red600}}" />
    <SolidColorBrush x:Key="CardBackgroundColor"
                     Color="{AppThemeBinding Light={StaticResource Gray50}, 
                                                           Dark={StaticResource Gray800}}" />
</ResourceDictionary>