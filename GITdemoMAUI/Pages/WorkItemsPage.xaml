<?xml
    version="1.0"
    encoding="utf-8"?>

<ContentPage
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:controls="clr-namespace:GITdemoMAUI.Pages.Controls"
    x:Class="GITdemoMAUI.Pages.WorkItemsPage">

    <ContentPage.ToolbarItems><!-- Az oldal tetején (toolbar-ban) jelennek meg az ide beírtak -->
        <ToolbarItem
            Text="+"
            Command="{Binding AddNewItemCommand}" />
        <!-- Command: A + jelre kattintva meghívandó command hozzárendelése -->
    </ContentPage.ToolbarItems>

    <Grid
        BackgroundColor="{DynamicResource AppBackgroundColor}">
        <Label
            Grid.Row="0"
            Text="{Binding PageTitle}"
            Style="{StaticResource TitleLabelStyle}"
            Margin="16,16,16,0" />
        <RefreshView
            Grid.Row="1"
            Margin="16"
            IsRefreshing="{Binding IsRefreshing}"
            Command="{Binding RefreshCommand}">

            <CollectionView
                ItemsSource="{Binding Items}"
                SelectionMode="None">

                <!-- Ezt írja ki, ha üres a CollectionView, mert nincs elem a megadott Items kollekcióban  -->
                <CollectionView.EmptyView>
                    <VerticalStackLayout
                        Padding="20"
                        Spacing="10"
                        Margin="0,20,0,0">
                        <Label
                            Text="Még nincs egyetlen feladat semm."
                            FontSize="30" />
                        <Label
                            Text="Nyomd meg jobb fent a + gpmbot, új feladat felvételéhez!"
                            Opacity="0.8" />
                    </VerticalStackLayout>
                </CollectionView.EmptyView>

                <!-- Az egyes elemeket így jelenítse meg: -->
                <CollectionView.ItemTemplate>
                    <DataTemplate>


                        <SwipeView
                            SwipeStarted="OnSwipeStarted"
                            SwipeEnded="OnSwipeEnded">


                            <!-- Balra húzás -->
                            <SwipeView.RightItems>
                                <SwipeItems
                                    Mode="Reveal">
                                    <SwipeItem
                                        Text="Módosítás"
                                        BackgroundColor="{StaticResource Blue600}"
                                        Invoked="OnEditInvoked" />
                                    <SwipeItem
                                        Text="Törlés"
                                        BackgroundColor="{StaticResource Red600}"
                                        Invoked="OnDeleteInvoked" />
                                </SwipeItems>
                            </SwipeView.RightItems>

                            <!-- Egy kártya kirajzolása -->
                            <Frame
                                Style="{StaticResource CardContainerStyle}">
                                <Frame.GestureRecognizers>
                                    <TapGestureRecognizer
                                        Tapped="OnItemTapped" />
                                </Frame.GestureRecognizers>
                                <VerticalStackLayout
                                    Spacing="6">
                                    <Label
                                        Text="{Binding Title}"
                                        FontAttributes="Bold"
                                        FontSize="16" />
                                    <Label
                                        Text="{Binding Description}"
                                        FontSize="14" />
                                    <Label
                                        Text="{Binding Status}"
                                        FontSize="12" />
                                </VerticalStackLayout>
                            </Frame>
                        </SwipeView>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>

        </RefreshView>
        <controls:BusyOverlayView />
    </Grid>
</ContentPage>