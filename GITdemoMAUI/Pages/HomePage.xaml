<?xml version="1.0" encoding="utf-8"?>

<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="GITdemoMAUI.Pages.HomePage">

        <VerticalStackLayout Spacing="12" Padding="16">
            <Label Text="Demo work példa" FontSize="24" />
            <Label 
                   Text="{Binding NowText}"
                   FontSize="16" />
            <!-- Text: Bindigolja az ModelView property geterét, hogy mit jelenítsen meg itt -->

            <Button Text="Idő frissítése"
                    Command="{Binding RefreshCommand}" />
            <!-- Command: (Clicked helyett) a ViewModelben létrehozott ICommandot hajtja végre -->
        </VerticalStackLayout>

</ContentPage>