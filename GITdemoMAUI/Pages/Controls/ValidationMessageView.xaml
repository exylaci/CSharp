<?xml
    version="1.0"
    encoding="utf-8"?>

<ContentView
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    x:Class="GITdemoMAUI.Pages.Controls.ValidationMessageView">


    <Label
        Text="{Binding Message, 
        Source={RelativeSource AncestorType={x:Type ContentView}}}"
        TextColor="{DynamicResource Danger}"
        IsVisible="{Binding IsVisibleMessage,
        Source={RelativeSource AncestorType={x:Type ContentView}}}" />
    <!-- Source={RelativeSource AncestorType={x:Type ContentView}} Ez kell ahhoz, hogy a megfelelő helyen keresse a Message változót a Binding, mivel az ő szülőjében (ehhez tartozó codebehind xaml.cs-ben) nincsen beállítva BindingContext. Ezért ne azt próválja használni, hanem kezjen el visszafelé lépkedni a vizuális fában és a legközelebbi (elsőnek megtalált) ContetView-t használja. És abban keressen Message változót. És ugyanez érvényes az IsVisibleMessage változóhoz kötésre is. -->

</ContentView>