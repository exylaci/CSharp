<?xml
    version="1.0"
    encoding="UTF-8"?>

<Shell
    x:Class="GITdemoMAUI.AppShell"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:pages="clr-namespace:GITdemoMAUI.Pages"
    Title="GITdemoMAUI">

    <!-- A két oldalunk közötti váltáshoz: -->
    <TabBar>
        <ShellContent
            Title="Kezdőlap"
            Route="HomePage"
            ContentTemplate="{DataTemplate pages:HomePage}" />
        <!-- egér áll a HomePage-n / alt+enter / Import type: 'GITdemoMAUI.Pages.HomePage' -re megcsinálja a fenti: xmlns:pages="clr-namespace:GITdemoMAUI.Pages" -t -->
        <ShellContent
            Title="Munkák"
            Route="WorkItemsPage"
            ContentTemplate="{DataTemplate pages:WorkItemsPage}" />
        <ShellContent
            Title="Új munka felvétele"
            Route="WorkItemEditorPage"
            ContentTemplate="{DataTemplate pages:WorkItemEditorPage}" />
        <ShellContent
            Title="Beállítások"
            Route="SettingsPage"
            ContentTemplate="{DataTemplate pages:SettingsPage}" />
    </TabBar>

</Shell>